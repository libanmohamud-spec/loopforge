{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "THREAT_MODEL",
  "description": "Structured threat model. The verifier enforces structure, referential integrity, and coverage on top of this schema. JSON Schema alone cannot express the cross-reference rules; see verify.py.",
  "type": "object",
  "required": ["system", "assets", "trust_boundaries", "entry_points", "threats", "mitigations"],
  "properties": {
    "system": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "classification"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "classification": { "enum": ["public", "internal", "confidential", "restricted"] }
        }
      }
    },
    "trust_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "between": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "entry_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "boundary", "auth"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "boundary": { "type": "string", "description": "id of a trust_boundary" },
          "auth": { "enum": ["none", "user", "service", "admin"] }
        }
      }
    },
    "threats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "stride", "entry_point", "assets", "severity", "mitigations"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "stride": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["S", "T", "R", "I", "D", "E"] },
            "description": "Spoofing, Tampering, Repudiation, Information disclosure, Denial of service, Elevation of privilege"
          },
          "entry_point": { "type": "string", "description": "id of an entry_point" },
          "assets": { "type": "array", "items": { "type": "string" }, "description": "ids of assets" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "mitigations": { "type": "array", "items": { "type": "string" }, "description": "ids of mitigations" }
        }
      }
    },
    "mitigations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "status"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "status": { "enum": ["proposed", "implemented", "accepted-risk"] }
        }
      }
    }
  }
}
